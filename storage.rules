rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Recipe images - allow public read and write for recipe imports
    // This allows users to import recipes even without authentication
    match /recipe-images/{imageId} {
      // Allow anyone to read recipe images
      allow read: if true;
      
      // Allow public uploads for recipe images (required for recipe import feature)
      // File size limit: 10MB (10485760 bytes)
      // More permissive: allow if size is reasonable, content type check is optional
      allow write: if request.resource.size < 10485760;
    }
    
    // Default: deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

match /kitchenInvites/{inviteId} {
  // Allow anyone to read invites (needed for validation)
  allow read: if true;

  // Only authenticated users can create invites
  allow create: if request.auth != null
    && request.resource.data.createdBy == request.auth.uid
    && request.resource.data.kitchenId is string
    && request.resource.data.used == false;

  // Only allow updates to mark invite as used (via backend/Cloud Function)
  // For now, we allow updates from authenticated users
  // You may want to restrict this further with Cloud Functions
  allow update: if request.auth != null
    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['used'])
    && request.resource.data.used == true;

  // No deletes
  allow delete: if false;
}